<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/label_layout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Transaction Label"
        app:errorEnabled="true"
        app:startIconDrawable="@drawable/baseline_label_24">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/transaction_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/amount_layout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Amount"
        app:errorEnabled="true"
        app:prefixText="₱"
        app:startIconDrawable="@drawable/baseline_currency_ruble_24">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/transaction_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_allowance_transaction"
            style="@style/Widget.AllowanceCalculator.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"
            android:layout_weight="1"
            app:icon="@drawable/baseline_add_24"
            android:backgroundTint="@color/success"
            android:insetTop="20dp"
            android:insetBottom="20dp"
            app:iconGravity="textTop"
            app:iconPadding="8dp"
            android:padding="15dp"
            app:iconSize="50sp"
            android:text="ALLOWANCE" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_expense_transaction"
            style="@style/Widget.AllowanceCalculator.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_weight="1"
            android:backgroundTint="@color/error"
            app:icon="@drawable/baseline_remove_24"
            android:insetTop="20dp"
            android:insetBottom="20dp"
            app:iconGravity="textTop"
            app:iconPadding="8dp"
            android:padding="15dp"
            app:iconSize="50sp"
            android:text="EXPENSE" />
    </LinearLayout>

</LinearLayout>