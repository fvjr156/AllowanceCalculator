<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Theme - Inherits from light theme and overrides -->
    <style name="Theme.AllowanceCalculator" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Keep all light theme settings, only override specific items -->

        <!-- Status Bar -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Higher elevation for better contrast -->
        <item name="cardElevation">4dp</item>

        <!-- EditText specific for dark mode -->
        <item name="editTextStyle">@style/Widget.AllowanceCalculator.EditText.Dark</item>
    </style>

    <!-- Dark Mode EditText -->
    <style name="Widget.AllowanceCalculator.EditText.Dark" parent="Widget.AllowanceCalculator.EditText">
        <item name="boxStrokeColor">@color/border_light</item>
        <item name="android:textColorHint">@color/text_hint_light</item>
        <item name="hintTextColor">@color/text_hint_light</item>
    </style>
</resources>