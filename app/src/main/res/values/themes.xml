<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Light Theme -->
    <style name="Theme.AllowanceCalculator" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryDark">@color/primary_blue_dark</item>
        <item name="colorPrimaryVariant">@color/primary_blue_light</item>

        <!-- Accent Color -->
        <item name="colorAccent">@color/accent_green</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSecondaryVariant">@color/accent_green_dark</item>

        <!-- Background Colors -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/background_surface_light</item>
        <item name="colorBackgroundFloating">@color/background_card_light</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary_light</item>
        <item name="android:textColorSecondary">@color/text_secondary_light</item>
        <item name="android:textColorHint">@color/text_hint_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="colorOnBackground">@color/text_primary_light</item>

        <!-- Status & Navigation Bar -->
        <item name="android:statusBarColor">@color/primary_blue_dark</item>
        <item name="android:navigationBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.AllowanceCalculator.Button</item>
        <item name="cardViewStyle">@style/Widget.AllowanceCalculator.CardView</item>
        <item name="editTextStyle">@style/Widget.AllowanceCalculator.EditText</item>

        <!-- Typography -->
        <item name="fontFamily">@font/sfprodisplayregular</item>
        <item name="android:textAppearance">@style/TextAppearance.AllowanceCalculator.Body1</item>

        <!-- Corner Radius -->
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.AllowanceCalculator.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="fontFamily">@font/sfprodisplaymedium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AllowanceCalculator.Title" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="fontFamily">@font/sfprodisplaymedium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AllowanceCalculator.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="fontFamily">@font/sfprodisplayregular</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.AllowanceCalculator.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_secondary_light</item>
        <item name="fontFamily">@font/sfprodisplayregular</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.AllowanceCalculator.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_hint_light</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.AllowanceCalculator.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAppearance">@style/TextAppearance.AllowanceCalculator.Button</item>
    </style>

    <style name="TextAppearance.AllowanceCalculator.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- CardView Style -->
    <style name="Widget.AllowanceCalculator.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardBackgroundColor">@color/background_card_light</item>
    </style>

    <!-- EditText Style -->
    <style name="Widget.AllowanceCalculator.EditText" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxStrokeColor">@color/border_light</item>
        <item name="android:textColorHint">@color/text_hint_light</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.AllowanceCalculator.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/background_card_light</item>
        <item name="chipStrokeColor">@color/border_light</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>
</resources>