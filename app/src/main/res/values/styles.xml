<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Outlined Button -->
    <style name="Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/border_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textAppearance">@style/TextAppearance.AllowanceCalculator.Button</item>
    </style>

    <!-- Text Button -->
    <style name="Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAppearance">@style/TextAppearance.AllowanceCalculator.Button</item>
    </style>

    <!-- Success Button -->
    <style name="Button.Success" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/success</item>
        <item name="android:textAppearance">@style/TextAppearance.AllowanceCalculator.Button</item>
    </style>

    <!-- Divider -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider_light</item>
    </style>

    <!-- Toolbar -->
    <style name="Toolbar.AllowanceCalculator" parent="Widget.MaterialComponents.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.AllowanceCalculator.Title</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.AllowanceCalculator.Body2</item>
        <item name="android:background">@color/primary_blue</item>
        <item name="android:minHeight">56dp</item>
    </style>
</resources>